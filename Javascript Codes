//Safe Attribute Getter (Reusable Utility)
function getAttr(attrName, index = null) {
    try {
        return index !== null 
            ? CPQJS.getAttributeVal(attrName, index) 
            : CPQJS.getAttributeVal(attrName);
    } catch (e) {
        console.warn(`Error getting ${attrName}`, e);
        return null;
    }
}

//Safe Attribute State Setter (Reusable)
function setFieldEditable(field, isEditable, index = null) {
    try {
        CPQJS.setAttributeState(field, { updatable: isEditable }, index);
    } catch (e) {
        console.warn(`Error updating ${field}`, e);
    }
}

//String → Array Parser (Very Useful)
function parseDelimitedString(data, rowDelim = "#$#", colDelim = "!@!") {
    if (!data) return [];

    return data.split(rowDelim).map(row => {
        const cols = row.split(colDelim);
        return cols.length > 1 ? cols : null;
    }).filter(Boolean);
}

